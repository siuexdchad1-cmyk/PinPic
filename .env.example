# =============================================================================
# PInPic — Environment Variable Blueprint
# Curriculum and Lab Standards Curated by Prathamesh Sir
# =============================================================================
# Copy this file to .env.local and fill in your actual values.
# NEVER commit .env.local to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# SUPABASE — https://supabase.com/dashboard
# Get these from: Project Settings → API
# -----------------------------------------------------------------------------

# Your Supabase project URL (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase anon/public key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Your Supabase service role key (SECRET — server-side only, never expose to browser)
# Used for admin operations: RLS bypass, seeding hotspots, email triggers
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# -----------------------------------------------------------------------------
# GROQ — https://console.groq.com
# Get your API key from: API Keys section (free developer tier)
# Models used:
#   - llama-3.3-70b-versatile        → caption synthesis
#   - meta-llama/llama-3.2-11b-vision-preview → composition matching
# -----------------------------------------------------------------------------

GROQ_API_KEY=gsk_your-groq-api-key-here

# -----------------------------------------------------------------------------
# RESEND — https://resend.com/api-keys
# Free tier: 3,000 emails/month, 100/day
# Verify your sending domain at: resend.com/domains
# For testing without a domain, use: onboarding@resend.dev (Resend sandbox)
# -----------------------------------------------------------------------------

RESEND_API_KEY=re_your-resend-api-key-here

# The verified "From" address for outgoing emails
# Example: PinPic <hello@yourdomain.com>
# Sandbox fallback: onboarding@resend.dev
RESEND_FROM_EMAIL=PinPic <onboarding@resend.dev>

# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------

# The public-facing base URL of your deployment
# Development: http://localhost:3000
# Production:  https://your-pinpic-domain.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# SETUP CHECKLIST (run these steps in order)
# -----------------------------------------------------------------------------
# 1. Create a Supabase project at supabase.com
# 2. Enable the PostGIS extension:
#    Supabase Dashboard → Database → Extensions → search "postgis" → Enable
# 3. Run the migration:
#    Supabase Dashboard → SQL Editor → paste contents of supabase/migrations/001_init.sql → Run
# 4. Copy this file: cp .env.example .env.local
# 5. Fill in all values above
# 6. npm install
# 7. npm run dev
# =============================================================================
